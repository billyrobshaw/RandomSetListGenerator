@page "/"
@using MusicApp.UI2.Models
@using MusicApp.UI2.Services
@inject MusicService MusicService
@inject IJSRuntime JS
@implements IDisposable

@if (showIntro)
{
    <div class="intro-wrapper">
        <div class="intro-card text-center shadow-sm">

            <h3 class="fw-bold mb-2">🎵 Preparing your first song…</h3>

            <p class="text-muted mb-3">
                Starting in <strong>@introCountdown</strong> seconds
            </p>

            <div class="mt-3">
                <p class="mb-1">
                    <strong>First Song:</strong> @music[currentIndex].SongTitle
                </p>
                <p class="text-muted mb-0">
                    @music[currentIndex].Artist
                </p>
            </div>

        </div>
    </div>
}
else if (music != null && music.Count > 0)
{
    <div class="page-wrapper">
        <div class="content-wrapper">

            <div class="music-card shadow-sm text-center">

                <h2>@music[currentIndex].SongTitle</h2>
                <h5>@music[currentIndex].Artist</h5>

                <div id="lyricsBox" class="lyrics-box mt-4">
                    <pre class="lyrics-text">@music[currentIndex].Lyrics</pre>
                </div>

                @if (!string.IsNullOrWhiteSpace(music[currentIndex].Chords))
                {
                    <div class="chords-box mx-auto">
                        <strong>Chords</strong>
                        <div class="mt-2">@music[currentIndex].Chords</div>
                    </div>
                }

                @if (showTransitionMessage)
                {
                    <p class="fw-bold text-primary mt-4">🎵 Get ready for the next song...</p>
                    <p class="text-muted">Next song starts in @transitionRemaining seconds</p>

                    @if (nextIndex != null)
                    {
                        <p class="mt-2">
                            👉 <strong>Coming Up:</strong> @music[nextIndex.Value].SongTitle<br />
                            <span class="text-muted">@music[nextIndex.Value].Artist</span>
                        </p>
                    }
                }

            </div>
        </div>

        <div class="footer-info">
            <p class="text-muted">⏱ Duration: @music[currentIndex].Duration.ToString(@"mm\:ss")</p>
            <p class="fw-bold text-danger">
                ⏳ Time Remaining: @remainingTime.ToString(@"mm\:ss")
            </p>
            <button class="btn btn-primary" @onclick="SkipSong">⏭ Skip</button>
        </div>
    </div>
}

@code {
    private List<MusicDto>? music;
    private bool loading = true;
    private int currentIndex = 0;
    private TimeSpan remainingTime;
    private int? nextIndex = null;
    private bool showIntro = true;
    private int introCountdown = 10;

    private CancellationTokenSource? cts;
    private bool showTransitionMessage = false;
    private int transitionRemaining = 0;

    private bool firstRenderComplete = false;

    protected override async Task OnInitializedAsync()
    {
        music = await MusicService.GetAllMusic();
        loading = false;

        if (music != null && music.Count > 0)
        {
            var rnd = new Random();
            currentIndex = rnd.Next(0, music.Count);

            introCountdown = 10;
            showIntro = true;

            while (introCountdown > 0)
            {
                await Task.Delay(1000);
                introCountdown--;
                await InvokeAsync(StateHasChanged);
            }

            showIntro = false;

            cts = new CancellationTokenSource();
            _ = PlaySongsLoop(cts.Token);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            firstRenderComplete = true;
        }
    }

    private async Task PlaySongsLoop(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested)
            {
                var song = music![currentIndex];
                remainingTime = song.Duration;

                if (remainingTime.TotalSeconds <= 0)
                    remainingTime = TimeSpan.FromSeconds(1);

                await Task.Delay(200);

                if (firstRenderComplete)
                    await JS.InvokeVoidAsync("resetLyricsScroll", "lyricsBox");

                var scrollInfo = await JS.InvokeAsync<ScrollInfo>("getScrollInfo", "lyricsBox");

                double scrollDistance = scrollInfo.scrollHeight - scrollInfo.clientHeight;
                double totalSeconds = song.Duration.TotalSeconds;

                if (totalSeconds < 1) totalSeconds = 1;

                double pixelsPerSecond = scrollDistance / totalSeconds;
                double pixelsPerTick = pixelsPerSecond * 0.125;

                if (pixelsPerTick < 0.5)
                    pixelsPerTick = 0.5;

                while (remainingTime.TotalSeconds > 0 && !token.IsCancellationRequested)
                {
                    if (firstRenderComplete)
                        await JS.InvokeVoidAsync("scrollLyricsSmooth", "lyricsBox", pixelsPerTick);

                    await Task.Delay(125, token);
                    remainingTime -= TimeSpan.FromMilliseconds(125);

                    await InvokeAsync(StateHasChanged);
                }

                showTransitionMessage = true;
                transitionRemaining = 15;

                var rnd = new Random();
                nextIndex = rnd.Next(0, music.Count);

                await InvokeAsync(StateHasChanged);

                while (transitionRemaining > 0 && !token.IsCancellationRequested)
                {
                    await Task.Delay(1000, token);
                    transitionRemaining--;
                    await InvokeAsync(StateHasChanged);
                }

                showTransitionMessage = false;

                currentIndex = nextIndex ?? new Random().Next(0, music.Count);
                nextIndex = null;

                if (firstRenderComplete)
                    await JS.InvokeVoidAsync("resetLyricsScroll", "lyricsBox");
            }
        }
        catch (TaskCanceledException)
        {
        }
    }

    public void Dispose()
    {
        cts?.Cancel();
        cts?.Dispose();
    }

    private async Task SkipSong()
    {
        cts?.Cancel();
        cts?.Dispose();

        var rnd = new Random();
        currentIndex = rnd.Next(0, music!.Count);

        if (firstRenderComplete)
            await JS.InvokeVoidAsync("resetLyricsScroll", "lyricsBox");

        remainingTime = music[currentIndex].Duration;

        showTransitionMessage = false;

        cts = new CancellationTokenSource();
        _ = PlaySongsLoop(cts.Token);

        await InvokeAsync(StateHasChanged);
    }

    public class ScrollInfo
    {
        public double scrollHeight { get; set; }
        public double clientHeight { get; set; }
    }
}
