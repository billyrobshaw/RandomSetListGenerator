@inherits LayoutComponentBase

<div class="app-container">
    <main class="app-main">
        @Body
    </main>

</div>

<style>
    .app-container {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background: linear-gradient(135deg, #e9eef5, #ffffff);
        font-family: "Inter", "Segoe UI", sans-serif;
    }

    .app-header {
        background: #ffffff;
        padding: 1rem 2rem;
        border-bottom: 1px solid #e5e5e5;
    }

    .app-title {
        margin: 0;
        font-size: 1.6rem;
        font-weight: 700;
        color: #1a1a1a;
    }

    .app-main {
        flex: 1;
        padding: 20px;
        display: flex;
        justify-content: center;
    }
</style>
